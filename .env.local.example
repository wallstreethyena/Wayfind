# Wayfind environment variables.
# For local testing, copy this file to ".env.local".
# For production, set each one in Vercel under Project Settings, Environment Variables.
#
# Only the Google key is public (it ships to the browser, which is why it is
# restricted to your domain). Every other key is a server secret: mark it
# "Sensitive" in Vercel and never prefix it with NEXT_PUBLIC.

# REQUIRED. Powers search, the map, and all place data.
# This is the key starting with AIza. Restrict it to your vercel.app domain.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=PASTE_YOUR_AIza_KEY_HERE

# REQUIRED for the AI. Powers the card one liners and the detail verdict.
# Get it at console.anthropic.com. Mark Sensitive in Vercel.
ANTHROPIC_API_KEY=PASTE_YOUR_ANTHROPIC_KEY_HERE

# OPTIONAL. Turns on the video section. Until set, that section stays hidden.
# A separate Google Cloud key with API restriction set to YouTube Data API v3
# only, and application restriction set to None. Mark Sensitive in Vercel.
YOUTUBE_API_KEY=PASTE_YOUR_YOUTUBE_KEY_HERE

# OPTIONAL. Turns on the Events tab. Until set, the tab says it is not on yet.
# Free Consumer Key from developer.ticketmaster.com. Mark Sensitive in Vercel.
TICKETMASTER_API_KEY=PASTE_YOUR_TICKETMASTER_KEY_HERE

# OPTIONAL. Adds SeatGeek events to the Plans feed (concerts, sports, theater).
# Free Client ID from seatgeek.com/account/develop. Use only the Client ID;
# the secret is not required. Mark Sensitive in Vercel.
SEATGEEK_CLIENT_ID=PASTE_YOUR_SEATGEEK_CLIENT_ID_HERE

# OPTIONAL. Adds PredictHQ events (festivals, community, expos, more).
# Access token from control.predicthq.com (free tier to start). Mark Sensitive.
PREDICTHQ_TOKEN=PASTE_YOUR_PREDICTHQ_TOKEN_HERE

# OPTIONAL and NOT self-serve. Bandsintown location search requires their
# gated partner program (the free key only returns a single artist). Leave
# blank until approved; the app ignores it when empty.
BANDSINTOWN_PARTNER_KEY=

# OPTIONAL but HIGH IMPACT for local coverage. Adds Google Events results
# (markets, festivals, free community events, bar gigs, art walks) by tapping
# how Google aggregates local listings. Get a key at serpapi.com (free tier
# ~250 searches/month; paid from $25/mo for 1,000). Mark Sensitive in Vercel.
SERPAPI_KEY=

# OPTIONAL and HIGHEST VOLUME for local coverage. OpenWeb Ninja Real-Time
# Events Search is also Google Events but returns up to 500 events per query
# and includes venue coordinates. Key from openwebninja.com (free tier; can
# sign up with Google). Mark Sensitive in Vercel. If you use this, you can
# remove SERPAPI_KEY since both pull Google Events.
OPENWEBNINJA_KEY=

# v4.86 — OPTIONAL but HIGH IMPACT. Second place source (multi-source
# aggregation): venues, categories, ratings, prices, photos merged with
# Google results and deduped. Key from foursquare.com/developers (legacy fsq3
# key or new service key — both work). Mark Sensitive in Vercel.
# NOTE: rating/photos/hours are Foursquare "rich data" fields — verify your
# plan returns them via /api/fsq/search?probe=1 after deploy.
FOURSQUARE_API_KEY=

# v4.08 — server-side Places proxy (shared cache). Create a SECOND key in Google
# Cloud with NO referrer restriction, API-restricted to "Places API (New)" only.
# Without this the app silently falls back to direct browser calls (old behavior).
GOOGLE_MAPS_SERVER_KEY=

# v4.14 affiliates
NEXT_PUBLIC_GYG_PID=
NEXT_PUBLIC_CJ_PID=

# Server-side only. Viator Partner API key — powers exact-product Book links.
# Get it at partners.viator.com under Developer API. Never NEXT_PUBLIC.
VIATOR_API_KEY=PASTE_YOUR_VIATOR_API_KEY

# Eventbrite (organizer-scoped; public search API was retired in 2020).
# Create a free API token at eventbrite.com/platform, then list the numeric
# organization ids of local orgs whose events you want in the feed.
EVENTBRITE_PRIVATE_TOKEN=PASTE_TOKEN
EVENTBRITE_ORG_IDS=123,456
