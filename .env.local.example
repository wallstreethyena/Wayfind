# Wayfind environment variables — the SINGLE SOURCE OF TRUTH for what the app reads.
# For local testing, copy this file to ".env.local".
# For production, set each one in Vercel → Project Settings → Environment Variables.
#
# Rules of the road:
#  - Only NEXT_PUBLIC_* values ship to the browser. NEVER put a secret behind a
#    NEXT_PUBLIC_ name. Every non-public key is a server secret → mark it
#    "Sensitive" in Vercel.
#  - REQUIRED  = the app is meaningfully broken without it.
#  - OPTIONAL  = the feature it powers is simply hidden until the key is set
#    (fail-soft everywhere — a missing optional key is never a crash; the server
#    logs one line naming which integrations are OFF, so an empty section reads
#    as "no key," not "broken feature").
#  - Placeholders only in this file — never commit a real value.
#  - Env reads use bracket notation in places (process.env["X"]) on purpose, for
#    reliable runtime reads — that's intentional, not a style slip.

# ============================================================================
# REQUIRED — the app is broken without these
# ============================================================================

# Supabase — accounts, saved places, lists, the shared server cache, and crons.
# The URL + anon key are public (client-side auth); the service-role key is a
# server secret that BYPASSES RLS — mark Sensitive, and NEVER give it a
# NEXT_PUBLIC_ name. SUPABASE_URL mirrors the public URL for server code
# (lib/serverCache.js reads SUPABASE_URL || NEXT_PUBLIC_SUPABASE_URL).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=PASTE_YOUR_SUPABASE_ANON_KEY
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=PASTE_YOUR_SERVICE_ROLE_KEY

# Google Maps/Places (client) — search, the map, and all place data.
# This is the AIza… key; restrict it to your domain (it ships to the browser).
NEXT_PUBLIC_GOOGLE_MAPS_KEY=PASTE_YOUR_AIza_KEY_HERE

# ----------------------------------------------------------------------------
# REQUIRED for the AI feature (the app still boots without it — the AI just
# stays off and cards fall back to local templates).
# ----------------------------------------------------------------------------
# Powers the card one-liners, the detail verdict, insider tips, and hooks.
# Get it at console.anthropic.com. Mark Sensitive. LLM_API_KEY is an accepted
# fallback (the app reads ANTHROPIC_API_KEY || LLM_API_KEY) — set EITHER, not both.
ANTHROPIC_API_KEY=PASTE_YOUR_ANTHROPIC_KEY_HERE
LLM_API_KEY=

# KILL-SWITCH for the "Insider Intel" card (lib/insiderServer.js). OFF by default
# (unset = off). The card is generated with NO evidence source — only name, type,
# rating, review count, and price — so it fabricates plausible-but-false local
# detail (it invented "cruise-ship crowds" for Marie Selby Botanical Gardens).
# Leave UNSET until the module is rebuilt on a real evidence source. Set to 1 ONLY
# to deliberately re-enable it. When off, getInsider() returns null before the
# cache read, so cached fabrications also stop serving.
INSIDER_ENABLED=

# ============================================================================
# FEATURE-GATE CALLOUT — set these in Vercel PRODUCTION or the feature stays dark
# ============================================================================

# Server-side Places proxy that feeds the shared Supabase cache. Create a SECOND
# Google Cloud key with NO referrer restriction, API-restricted to "Places API
# (New)". Mark Sensitive; never NEXT_PUBLIC.
# ABSENT = the app falls back to DIRECT browser calls to Google Places = exposed
# to Google Places 429s (the exact incident the server proxy + cache exist to
# prevent). Set this in Production to keep the cache + resilience on.
GOOGLE_MAPS_SERVER_KEY=

# Enables the place "video reviews" block (the auto YouTube strip that
# CreatorFeature keeps as its secondary tier). A separate Google Cloud key,
# API-restricted to "YouTube Data API v3", application restriction None. Sensitive.
# ABSENT = that strip renders empty in Production — a missing KEY, not a broken
# feature. Set this in Production to light up the video-reviews section.
YOUTUBE_API_KEY=PASTE_YOUR_YOUTUBE_KEY_HERE

# ============================================================================
# OPTIONAL — event sources (each absent source is skipped; the feed still works)
# ============================================================================

# Ticketmaster. Free Consumer Key from developer.ticketmaster.com. Sensitive.
TICKETMASTER_API_KEY=PASTE_YOUR_TICKETMASTER_KEY_HERE

# SeatGeek (concerts, sports, theater). Free Client ID from
# seatgeek.com/account/develop. The Client ID alone is enough; the secret is
# OPTIONAL (sent when present). Sensitive.
SEATGEEK_CLIENT_ID=PASTE_YOUR_SEATGEEK_CLIENT_ID_HERE
SEATGEEK_CLIENT_SECRET=

# PredictHQ (festivals, community, expos). Access token from control.predicthq.com
# (free tier to start). Sensitive.
PREDICTHQ_TOKEN=PASTE_YOUR_PREDICTHQ_TOKEN_HERE

# Google Events via SerpApi (markets, festivals, bar gigs, art walks). Key from
# serpapi.com (free ~250 searches/mo). Sensitive. If you use OPENWEBNINJA_KEY you
# can leave this blank — both pull Google Events.
SERPAPI_KEY=

# Google Events via OpenWeb Ninja — higher volume (up to 500/query, with venue
# coords). Key from openwebninja.com (free tier). Sensitive.
OPENWEBNINJA_KEY=

# Eventbrite (organizer-scoped; the public search API was retired in 2020). Create
# a free API token at eventbrite.com/platform, then list the numeric organization
# ids whose events you want in the feed. Token is Sensitive.
EVENTBRITE_PRIVATE_TOKEN=PASTE_TOKEN
EVENTBRITE_ORG_IDS=123,456

# Bandsintown — NOT self-serve. Requires their gated partner program (the free key
# only returns a single artist). Leave blank until approved; ignored when empty.
BANDSINTOWN_PARTNER_KEY=

# ============================================================================
# OPTIONAL — place enrichment + outdoors
# ============================================================================

# Foursquare — a second place source merged + deduped with Google. Legacy fsq3 key
# or new service key (both work). Sensitive. NOTE: rating/photos/hours are "rich
# data" fields — verify your plan returns them via /api/fsq/search?probe=1.
FOURSQUARE_API_KEY=

# Outdoor/recreation sources (server-only; never NEXT_PUBLIC). NPS: free key from
# nps.gov/subjects/developer. RIDB: free key from ridb.recreation.gov. OSM needs none.
NPS_API_KEY=
RIDB_API_KEY=

# Tripadvisor ratings. Canonical name: TRIPADVISOR_API_KEY. Accepted fallbacks, in
# this order: TA_API_KEY, then TRIPADVISOR_KEY (see app/api/ta/place/route.js). Set
# exactly ONE. Sensitive.
TRIPADVISOR_API_KEY=
# TA_API_KEY=
# TRIPADVISOR_KEY=

# ============================================================================
# OPTIONAL — affiliates (revenue links; most work untracked until a PID is set)
# ============================================================================

# Viator Partner API key — powers exact-product Book links (server-only). Get it at
# partners.viator.com under Developer API. Sensitive; never NEXT_PUBLIC.
VIATOR_API_KEY=PASTE_YOUR_VIATOR_API_KEY
# Public Viator partner/tracking id appended to outbound Viator links.
NEXT_PUBLIC_VIATOR_PID=
# GetYourGuide + CJ affiliate partner ids (public).
NEXT_PUBLIC_GYG_PID=
NEXT_PUBLIC_CJ_PID=

# ============================================================================
# OPTIONAL — analytics, site, ops, email, crons
# ============================================================================

# PostHog product analytics (public project key). Absent = analytics off.
NEXT_PUBLIC_POSTHOG_KEY=

# Canonical site URL. Defaults to https://www.gowayfind.com when unset; override
# only for a preview/staging origin.
NEXT_PUBLIC_SITE_URL=https://www.gowayfind.com

# Gates the cron routes (fail-closed: a cron 401s without this). Sensitive.
CRON_SECRET=

# Gates /api/metrics/share. Sensitive.
METRICS_SECRET=

# Optional webhook pinged on a new signup (e.g. a Slack/Zapier URL).
SIGNUP_WEBHOOK_URL=

# Email (digests/notifications) via Resend — key is Sensitive; DIGEST_EMAIL is the
# recipient address for ops digests.
RESEND_API_KEY=
DIGEST_EMAIL=

# Google PageSpeed Insights key for the Core Web Vitals cron. Sensitive.
PAGESPEED_API_KEY=
